---
---
<section id="features" class="max-w-5xl mx-auto px-6 pb-24">
  <h2 class="text-xl font-semibold mb-8 font-mono" style="color: #e6edf3;">
    <span style="color: #b5843a;">#</span> Features
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

    <!-- Issue grouping -->
    <div class="rounded-lg p-5" style="background-color: #161b22; border: 1px solid #21262d;">
      <div class="mb-3" style="color: #b5843a;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 3h7v7H3z"/>
          <path d="M14 3h7v7h-7z"/>
          <path d="M14 14h7v7h-7z"/>
          <path d="M3 14h7v7H3z"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e6edf3;">Issue grouping</h3>
      <p class="text-sm leading-relaxed" style="color: #8b949e;">
        Events with the same root cause group into one issue. Fingerprinted by exception type, message, and stack trace. No noise.
      </p>
    </div>

    <!-- Alerts -->
    <div class="rounded-lg p-5" style="background-color: #161b22; border: 1px solid #21262d;">
      <div class="mb-3" style="color: #b5843a;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e6edf3;">Alerts</h3>
      <p class="text-sm leading-relaxed" style="color: #8b949e;">
        Webhook alerts to Slack, Discord, or any HTTP endpoint. Three conditions: new issue, regression, event count threshold.
      </p>
    </div>

    <!-- Weekly digest -->
    <div class="rounded-lg p-5" style="background-color: #161b22; border: 1px solid #21262d;">
      <div class="mb-3" style="color: #b5843a;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e6edf3;">Weekly digest</h3>
      <p class="text-sm leading-relaxed" style="color: #8b949e;">
        One email per week covering all your projects. Stats, top issues, links. Configurable day and hour.
      </p>
    </div>

    <!-- Live log stream -->
    <div class="rounded-lg p-5" style="background-color: #161b22; border: 1px solid #21262d;">
      <div class="mb-3" style="color: #b5843a;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e6edf3;">Live log stream</h3>
      <p class="text-sm leading-relaxed" style="color: #8b949e;">
        Ingest structured logs alongside errors. Stream them live in the UI over SSE.
      </p>
    </div>

    <!-- Multi-project -->
    <div class="rounded-lg p-5" style="background-color: #161b22; border: 1px solid #21262d;">
      <div class="mb-3" style="color: #b5843a;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e6edf3;">Multi-project</h3>
      <p class="text-sm leading-relaxed" style="color: #8b949e;">
        One BugBarn instance, multiple projects. Unified "all projects" view with per-project chips.
      </p>
    </div>

    <!-- Source maps -->
    <div class="rounded-lg p-5" style="background-color: #161b22; border: 1px solid #21262d;">
      <div class="mb-3" style="color: #b5843a;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="16 18 22 12 16 6"/>
          <polyline points="8 6 2 12 8 18"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e6edf3;">Source maps</h3>
      <p class="text-sm leading-relaxed" style="color: #8b949e;">
        Upload JavaScript source maps to get original file names and line numbers in stack traces.
      </p>
    </div>

    <!-- CLI -->
    <div class="rounded-lg p-5" style="background-color: #161b22; border: 1px solid #21262d;">
      <div class="mb-3" style="color: #b5843a;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="4 17 10 11 4 5"/>
          <line x1="12" y1="19" x2="20" y2="19"/>
        </svg>
      </div>
      <h3 class="font-semibold text-sm mb-1.5" style="color: #e6edf3;">CLI client</h3>
      <p class="text-sm leading-relaxed" style="color: #8b949e;">
        <code>bb</code> — query issues, live-tail logs, manage projects. JSON output for AI agents, interactive TUI for developers.
      </p>
    </div>

  </div>
</section>
