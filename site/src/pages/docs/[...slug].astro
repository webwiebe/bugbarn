---
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries
    .filter(e => e.slug.toLowerCase() !== 'readme')
    .map(entry => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

// Extract title from first h1 heading if no frontmatter title
const title = entry.data.title ?? headings.find((h: { depth: number; text: string }) => h.depth === 1)?.text ?? entry.slug;
---
<DocsLayout title={title} description={entry.data.description} currentSlug={entry.slug}>
  <Content />
</DocsLayout>
