{
  "statusLine": {
    "type": "command",
    "command": "bb issues 2>/dev/null | python3 -c \"import sys,json; d=json.load(sys.stdin); issues=d.get('issues') or []; print(f'🐛 {len(issues)} open')\""
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/go-build-check.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit)",
            "command": ".claude/hooks/pre-commit.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "if": "Bash(gh pr create)",
            "command": ".claude/hooks/pre-pr.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
