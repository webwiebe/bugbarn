{
  "name": "bugbarn-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && node build.mjs",
    "lint": "npm run lint:tsc && npm run lint:eslint",
    "lint:tsc": "tsc --noEmit",
    "lint:eslint": "eslint src/",
    "test": "tsc -p tsconfig.json --noEmit",
    "test:e2e": "playwright test",
    "screenshots": "playwright test e2e/screenshots.spec.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.27.0",
    "globals": "^16.1.0",
    "typescript": "^5.8.3"
  }
}
